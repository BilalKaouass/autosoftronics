---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ScrollReveal from "../../components/ScrollReveal.astro";
import { services } from "../../data/services";

export function getStaticPaths() {
  return services.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const service = services.find((s) => s.slug === slug);

if (!service) throw new Error(`Service introuvable: ${slug}`);

/** 🎨 Overlay par service */
const tone = {
  diagnostic: { a: "59,130,246", b: "139,92,246" },
  programmation: { a: "139,92,246", b: "217,70,239" },
  reparation: { a: "245,158,11", b: "139,92,246" },
} as const;

const t = tone[service.slug] ?? { a: "139,92,246", b: "59,130,246" };

/** ✅ Badge confiance par service */
const trust = {
  diagnostic: "+250 véhicules diagnostiqués",
  programmation: "Procédures sécurisées & sauvegarde ECU",
  reparation: "Réparations durables, tests avant/après",
} as const;

const trustText = trust[service.slug] ?? "Atelier spécialisé – service premium";

const bgUrl = `/assets/services/${service.slug}.jpg`;

/** ✅ FAQ ciblée par service */
const serviceFaq = {
  diagnostic: [
    {
      q: "Combien coûte un diagnostic électronique automobile ?",
      a: "Le prix dépend du véhicule, des symptômes et du niveau de recherche nécessaire. Un diagnostic simple ne demande pas le même temps qu’une panne électronique complexe. Contactez-nous avec le modèle, l’année et le problème pour recevoir une estimation claire."
    },
    {
      q: "Combien de temps prend un diagnostic électronique ?",
      a: "La durée dépend de la complexité de la panne. Certains diagnostics sont rapides, d’autres demandent des contrôles plus poussés, des mesures ou des vérifications réseau. Notre objectif est d’identifier la cause réelle, pas seulement d’effacer un défaut."
    },
    {
      q: "Quels véhicules sont compatibles pour un diagnostic ?",
      a: "Nous intervenons sur de nombreuses marques et différents systèmes électroniques selon compatibilité. Le plus simple est de nous envoyer la marque, le modèle, l’année et la motorisation pour vérification."
    }
  ],
  programmation: [
    {
      q: "La programmation ECU est-elle sécurisée ?",
      a: "Oui, lorsqu’elle est réalisée avec méthode et après vérification de compatibilité. Nous privilégions les procédures maîtrisées, les sauvegardes lorsque c’est nécessaire et une validation après intervention."
    },
    {
      q: "Pouvez-vous coder ou adapter des modules électroniques ?",
      a: "Oui, selon le véhicule et le module concerné, nous réalisons des opérations de codage, d’adaptation, de configuration ou de programmation."
    },
    {
      q: "Tous les calculateurs peuvent-ils être programmés ?",
      a: "Non, cela dépend de la génération du véhicule, du type de calculateur, de son état et de la compatibilité de la procédure. Nous vérifions cela avant toute intervention."
    }
  ],
  reparation: [
    {
      q: "Peut-on réparer un calculateur électronique automobile ?",
      a: "Dans certains cas oui, selon la panne, le type de boîtier et l’état réel des composants. Dans d’autres cas, un remplacement ou une autre solution est plus adapté."
    },
    {
      q: "Faites-vous des tests après réparation ?",
      a: "Oui, nous privilégions une validation après intervention afin de vérifier le bon fonctionnement avant restitution."
    },
    {
      q: "Faut-il remplacer le module ou peut-on le réparer ?",
      a: "Cela dépend du type de panne et de la viabilité technique de la réparation. L’objectif est de proposer la solution la plus cohérente et la plus durable."
    }
  ]
} as const;

const faqItems = serviceFaq[service.slug] ?? [];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map((item) => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
---

<BaseLayout
  title={service.seo?.title ?? `${service.name} | Autosoftronics`}
  description={service.seo?.description ?? service.short}
>
  {faqItems.length ? (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  ) : null}

  <section
    class="svc relative overflow-hidden pt-24 pb-24"
    style={`--tone-a:${t.a}; --tone-b:${t.b}; --service-bg:url('${bgUrl}');`}
  >
    {/* Background via pseudo-element */}
    <div class="svc-bg" aria-hidden="true"></div>

    {/* Overlays */}
    <div class="pointer-events-none absolute inset-0 z-0 bg-gradient-to-b from-black/50 via-black/20 to-base-100"></div>
    <div
      class="pointer-events-none absolute inset-0 z-0"
      style={`background: radial-gradient(circle at 20% 15%, rgba(var(--tone-a), .22), transparent 55%);`}
    ></div>
    <div
      class="pointer-events-none absolute inset-0 z-0"
      style={`background: radial-gradient(circle at 80% 10%, rgba(var(--tone-b), .16), transparent 55%);`}
    ></div>
    <div class="pointer-events-none absolute inset-0 z-0 opacity-[0.04] bg-[radial-gradient(circle_at_1px_1px,white_1px,transparent_1px)] [background-size:22px_22px]"></div>

    <div class="relative z-10 max-w-6xl mx-auto px-4">
      {/* HERO */}
      <ScrollReveal>
        <div class="max-w-3xl">
          <a
            href="/services"
            class="inline-flex items-center gap-2 text-sm text-white/50 hover:text-white/80 transition"
          >
            <span>←</span>
            <span>Retour aux services</span>
          </a>

          <div class="mt-5">
            <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
              <span class="h-2 w-2 rounded-full bg-success"></span>
              {service.name}
            </div>
          </div>

          <h1 class="mt-6 text-4xl md:text-6xl font-bold tracking-tight leading-tight">
            {service.hero?.title ?? service.name}
          </h1>

          <p class="mt-4 text-white/70 leading-relaxed max-w-2xl">
            {service.hero?.subtitle ?? service.short}
          </p>

          {service.highlights?.length ? (
            <div class="mt-7 flex flex-wrap gap-2">
              {service.highlights.map((h) => (
                <span class="badge badge-outline border-white/20 text-white/70">
                  <span class="text-white/50 mr-2">{h.label}:</span> {h.value}
                </span>
              ))}
            </div>
          ) : null}

          <div class="mt-10 flex gap-3 flex-wrap">
            <a href="/contact" class="btn btn-primary btn-lg shadow-lg shadow-primary/25">
              Demander un devis
            </a>
            <a
              href="/contact"
              class="btn btn-outline btn-lg border-white/25 text-white hover:bg-white/10 hover:border-primary transition"
            >
              Poser une question
            </a>
          </div>

          <div class="mt-6 flex flex-wrap gap-3">
            <div class="trust-pill text-sm text-white/75">
              {trustText}
            </div>
          </div>
        </div>
      </ScrollReveal>

      {/* CONTENT GRID */}
      <div class="mt-16 grid lg:grid-cols-12 gap-8 items-start">
        {/* LEFT */}
        <ScrollReveal delay={120} class="min-w-0 lg:col-span-7">
          <div class="min-w-0 w-full space-y-6">
            <div class="glass-card relative rounded-3xl p-8 overflow-hidden min-w-0 w-full">
              <div class="sheen pointer-events-none absolute inset-0 rounded-3xl"></div>

              <div class="relative min-w-0">
                <div class="flex items-start justify-between gap-6 min-w-0">
                  <div class="min-w-0">
                    <h2 class="text-2xl font-bold">Ce que comprend la prestation</h2>
                    <p class="mt-2 text-white/60 text-sm">
                      Checklist claire — pour savoir exactement ce qui est inclus.
                    </p>
                  </div>

                  <div class="hidden sm:flex items-center gap-2 text-white/60 text-sm shrink-0">
                    <span class="h-2 w-2 rounded-full bg-primary/80"></span>
                    Méthode contrôlée
                  </div>
                </div>

                <ul class="mt-6 grid gap-3 sm:grid-cols-2 text-white/70 min-w-0">
                  {service.includes.map((line) => (
                    <li class="flex gap-3 min-w-0">
                      <span class="service-bullet mt-2 shrink-0"></span>
                      <span class="leading-relaxed min-w-0">{line}</span>
                    </li>
                  ))}
                </ul>
              </div>
            </div>

            <div class="glass-card relative rounded-3xl p-8 overflow-hidden min-w-0 w-full">
              <div class="sheen pointer-events-none absolute inset-0 rounded-3xl"></div>

              <div class="relative min-w-0 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6">
                <div class="min-w-0">
                  <h3 class="text-xl font-bold">Besoin d’un avis rapide ?</h3>
                  <p class="mt-2 text-white/70">
                    Expliquez votre problème, modèle et année — on confirme la compatibilité et la meilleure option.
                  </p>
                </div>
                <div class="shrink-0">
                  <a
                    href="/contact"
                    class="btn btn-outline btn-lg border-white/25 text-white hover:bg-white/10 hover:border-primary transition"
                  >
                    Vérifier la compatibilité
                  </a>
                </div>
              </div>
            </div>
          </div>
        </ScrollReveal>

        {/* RIGHT */}
        <ScrollReveal delay={180} class="min-w-0 lg:col-span-5">
          <aside class="min-w-0 w-full">
            <div class="glass-card relative rounded-3xl p-8 overflow-hidden min-w-0 w-full">
              <div class="sheen pointer-events-none absolute inset-0 rounded-3xl"></div>

              <div class="relative min-w-0">
                <div class="text-white/70 text-sm">Notre méthode</div>
                <h2 class="mt-1 text-2xl font-bold">Process en 3 étapes</h2>

                <ol class="mt-8 space-y-7">
                  {service.process.map((p, i) => (
                    <li class="flex gap-4 min-w-0">
                      <div class="flex flex-col items-center shrink-0">
                        <div class="step-pill">
                          <span class="step-dot"></span>
                          <span>{p.step}</span>
                        </div>

                        {i !== service.process.length - 1 ? (
                          <div class="step-line"></div>
                        ) : null}
                      </div>

                      <div class="min-w-0 pt-[2px]">
                        <div class="text-lg font-semibold leading-snug">{p.title}</div>
                        <p class="mt-2 text-sm text-white/65 leading-relaxed min-w-0">
                          {p.text}
                        </p>
                      </div>
                    </li>
                  ))}
                </ol>

                <div class="mt-10 rounded-2xl border border-white/10 bg-black/20 p-4">
                  <div class="text-sm text-white/70">
                    <span class="text-white font-semibold">Conseil :</span> envoyez une photo du tableau de bord / défaut si vous en avez.
                  </div>
                </div>
              </div>
            </div>
          </aside>
        </ScrollReveal>
      </div>

      {/* FAQ SERVICE SEO */}
      {faqItems.length ? (
        <div class="mt-20">
          <ScrollReveal>
            <div class="max-w-3xl">
              <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
                <span class="h-2 w-2 rounded-full bg-success"></span>
                Questions fréquentes
              </div>

              <h2 class="mt-6 text-3xl md:text-4xl font-bold tracking-tight">
                FAQ {service.name}
              </h2>

              <p class="mt-4 text-white/70 leading-relaxed max-w-2xl">
                Retrouvez ici les réponses aux questions fréquentes liées à cette prestation.
              </p>
            </div>
          </ScrollReveal>

          <div class="mt-10 space-y-4">
            {faqItems.map((item, index) => (
              <ScrollReveal delay={index * 40}>
                <details class="faq-item group">
                  <summary class="faq-summary">
                    <span class="faq-number">{String(index + 1).padStart(2, "0")}</span>
                    <span class="faq-question">{item.q}</span>
                    <span class="faq-icon">+</span>
                  </summary>

                  <div class="faq-answer">
                    <p>{item.a}</p>
                  </div>
                </details>
              </ScrollReveal>
            ))}
          </div>
        </div>
      ) : null}
    </div>

    <style>
      .svc, .svc * { min-width: 0; }

      /* ✅ Image en vrai background CSS */
      .svc-bg{
        position: absolute;
        inset: 0;
        z-index: 0;
        background-image: var(--service-bg);
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        opacity: .42;
        filter: brightness(.92) contrast(1.12) saturate(1.10);
        transform: scale(1.04);
      }

      /* Glass card */
      .glass-card{
        border: 1px solid rgba(255,255,255,.10);
        background: rgba(18,18,24,.35);
        backdrop-filter: blur(18px);
        -webkit-backdrop-filter: blur(18px);
        box-shadow:
          0 0 0 1px rgba(255,255,255,.04) inset,
          0 30px 60px rgba(0,0,0,.35);
        transition: transform .35s ease, border-color .35s ease, background .35s ease;
      }
      .glass-card:hover{
        border-color: rgba(255,255,255,.18);
        background: rgba(18,18,24,.44);
        transform: translateY(-2px);
      }

      /* Sweep */
      .sheen::before{
        content:"";
        position:absolute;
        inset:-45%;
        background: linear-gradient(
          115deg,
          transparent 46%,
          rgba(255,255,255,.08) 50%,
          transparent 54%
        );
        transform: translateX(-26%) rotate(8deg);
        opacity: 0;
        transition: transform .7s ease, opacity .7s ease;
      }
      .glass-card:hover .sheen::before{
        opacity: 1;
        transform: translateX(26%) rotate(8deg);
      }

      /* Timeline */
      .step-pill{
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.14);
        background: rgba(255,255,255,.05);
        color: rgba(255,255,255,.85);
        font-size: 12px;
        line-height: 1;
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        box-shadow: 0 0 0 1px rgba(255,255,255,.04) inset;
      }

      .step-dot{
        width: 8px;
        height: 8px;
        border-radius: 999px;
        background: rgba(var(--tone-a), .95);
        box-shadow: 0 0 0 4px rgba(var(--tone-a), .14), 0 0 18px rgba(var(--tone-a), .30);
        flex: 0 0 auto;
      }

      .step-line{
        width: 2px;
        flex: 1 1 auto;
        margin-top: 10px;
        border-radius: 999px;
        background: linear-gradient(
          to bottom,
          rgba(var(--tone-a), .70),
          rgba(255,255,255,.10),
          rgba(255,255,255,0)
        );
      }

      /* Trust badge animé */
      .trust-pill{
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 10px 14px;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.14);
        background: rgba(255,255,255,.05);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        box-shadow: 0 0 0 1px rgba(255,255,255,.04) inset;
        position: relative;
        overflow: hidden;
      }
      .trust-pill::before{
        content:"";
        width: 7px;
        height: 7px;
        border-radius: 999px;
        background: rgba(34,197,94,.95);
        box-shadow: 0 0 0 4px rgba(34,197,94,.12);
        flex: 0 0 auto;
      }
      .trust-pill::after{
        content:"";
        position:absolute;
        inset:-40%;
        background: radial-gradient(circle, rgba(255,255,255,.10), transparent 55%);
        opacity:.0;
        animation: trustGlow 2.8s ease-in-out infinite;
      }

      @keyframes trustGlow{
        0%,100%{ opacity:.0; transform: translate3d(-10%,0,0); }
        50%{ opacity:.55; transform: translate3d(10%,0,0); }
      }

      .service-bullet{
        width: 6px;
        height: 6px;
        border-radius: 999px;
        background: rgba(var(--tone-a), .95);
        box-shadow: 0 0 0 4px rgba(var(--tone-a), .12);
        display: inline-block;
      }

      /* FAQ */
      .faq-item{
        border: 1px solid rgba(255,255,255,.10);
        background: rgba(18,18,24,.28);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-radius: 1.5rem;
        overflow: hidden;
        transition: border-color .25s ease, background .25s ease, transform .25s ease;
      }

      .faq-item:hover{
        border-color: rgba(255,255,255,.18);
        background: rgba(18,18,24,.36);
        transform: translateY(-1px);
      }

      .faq-summary{
        list-style: none;
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 16px;
        align-items: center;
        padding: 22px 24px;
        cursor: pointer;
      }

      .faq-summary::-webkit-details-marker{
        display: none;
      }

      .faq-number{
        font-size: 12px;
        color: rgba(255,255,255,.45);
        min-width: 26px;
        font-variant-numeric: tabular-nums;
      }

      .faq-question{
        font-size: 17px;
        font-weight: 600;
        line-height: 1.4;
        color: rgba(255,255,255,.92);
      }

      .faq-icon{
        width: 28px;
        height: 28px;
        display: grid;
        place-items: center;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.12);
        background: rgba(255,255,255,.04);
        color: rgba(255,255,255,.75);
        transition: transform .25s ease, background .25s ease, border-color .25s ease;
        font-size: 18px;
        line-height: 1;
      }

      .faq-item[open] .faq-icon{
        transform: rotate(45deg);
        background: rgba(255,255,255,.08);
        border-color: rgba(255,255,255,.18);
      }

      .faq-answer{
        padding: 0 24px 22px 66px;
        color: rgba(255,255,255,.68);
        line-height: 1.8;
        font-size: 15px;
      }

      @media (max-width: 768px){
        .faq-summary{
          padding: 18px 18px;
          gap: 12px;
        }

        .faq-question{
          font-size: 16px;
        }

        .faq-answer{
          padding: 0 18px 18px 56px;
          font-size: 14px;
          line-height: 1.7;
        }
      }

      @media (prefers-reduced-motion: reduce){
        .glass-card, .sheen::before{ transition:none !important; }
        .glass-card:hover{ transform:none; }
        .sheen::before{ opacity:0 !important; }
        .faq-item, .faq-icon{ transition:none !important; }
        .faq-item:hover{ transform:none; }
      }
    </style>
  </section>
</BaseLayout>