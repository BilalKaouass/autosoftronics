---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroPremium from "../components/HeroPremium.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
  const brand = [
    { name: "Audi", src: "/assets/brand/Audi.png" },
    { name: "BMW", src: "/assets/brand/Bmw.png" },
    { name: "Mercedes", src: "/assets/brand/Mercedes.png" },
    { name: "Volkswagen", src: "/assets/brand/Volkswagen.png" },
    { name: "Peugeot", src: "/assets/brand/Peugeot.png" },
    { name: "Renault", src: "/assets/brand/Renault.png" },
    { name: "Citroën", src: "/assets/brand/Citroen.png" },
    { name: "Ford", src: "/assets/brand/Ford.png" },
    { name: "Opel", src: "/assets/brand/Opel.png" },
    { name: "Toyota", src: "/assets/brand/Toyota.png" },
    { name: "Nissan", src: "/assets/brand/Nissan.png" },
    { name: "Hyundai", src: "/assets/brand/Hyundai.png" },
  ];
---

<BaseLayout
  title="Autosoftronics | Diagnostic, Programmation, Réparation"
  description="Diagnostic précis, programmation et réparation automobile."
>
  <!-- HERO PREMIUM -->
  <HeroPremium />

  <!-- APPLE STICKY SECTION -->
 

  <!-- SERVICES PREMIUM -->
  <section class="relative overflow-hidden py-28">
  <!-- CINEMA BACKGROUND (no PNG) -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <!-- aurora glows -->
    <div class="absolute -top-32 left-1/2 h-80 w-[70rem] -translate-x-1/2 rounded-full blur-3xl opacity-20 bg-gradient-to-r from-primary via-accent to-secondary"></div>
    <div class="absolute -bottom-40 left-1/2 h-80 w-[70rem] -translate-x-1/2 rounded-full blur-3xl opacity-15 bg-gradient-to-r from-secondary via-primary to-accent"></div>

    <!-- vignette cinema -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_35%,rgba(0,0,0,.70)_100%)]"></div>

    <!-- subtle dot texture (lighter than before) -->
    <div class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(circle_at_1px_1px,white_1px,transparent_1px)] [background-size:22px_22px]"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
        <span class="h-2 w-2 rounded-full bg-success"></span>
        Prestations principales
      </div>

      <h2 class="mt-6 text-4xl md:text-5xl font-bold tracking-tight">
        Nos services
      </h2>

      <p class="mt-4 text-white/70 max-w-2xl mx-auto leading-relaxed">
        Une méthode claire : diagnostic précis, intervention adaptée, validation avant restitution.
      </p>

      <!-- PROCESS STRIP (remplit + ultra pro) -->
      <div class="mt-10 flex flex-col md:flex-row items-center justify-center gap-3">
        <div class="process-pill">
          <span class="process-n">1</span>
          <span>Diagnostic précis</span>
        </div>
        <div class="process-line hidden md:block"></div>
        <div class="process-pill">
          <span class="process-n">2</span>
          <span>Intervention adaptée</span>
        </div>
        <div class="process-line hidden md:block"></div>
        <div class="process-pill">
          <span class="process-n">3</span>
          <span>Validation & restitution</span>
        </div>
      </div>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      <!-- Diagnostic -->
      <a
        href="/services/diagnostic"
        class="group relative rounded-3xl border border-white/10 bg-base-200/40 backdrop-blur-xl p-7 md:p-8
               hover:border-white/20 hover:bg-base-200/55 transition"
      >
        <div class="absolute inset-0 rounded-3xl opacity-0 group-hover:opacity-100 transition
                    bg-gradient-to-r from-primary/12 via-accent/10 to-secondary/12"></div>

        <div class="relative">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="grid place-items-center h-12 w-12 rounded-2xl border border-white/10 bg-base-300/40">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="opacity-90">
                  <path d="M10 4h4M9 8h6M8 12h8M7 16h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <path d="M6 20h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <div class="text-sm text-white/60 font-medium">01 — Diagnostic</div>
                <div class="text-xl font-bold">Identifier la cause</div>
              </div>
            </div>

            <span class="badge badge-outline border-white/20 text-white/70">Rapide</span>
          </div>

          <p class="mt-5 text-white/70 leading-relaxed">
            Lecture défauts, tests ciblés, analyse capteurs/actionneurs et réseau CAN.
          </p>

          <ul class="mt-6 space-y-2 text-sm text-white/65">
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
              Rapport clair & recommandations
            </li>
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              Contrôles mesurés, pas d’approximation
            </li>
          </ul>

          <div class="mt-7 inline-flex items-center gap-2 font-semibold text-primary">
            En savoir plus
            <span class="transition group-hover:translate-x-1">→</span>
          </div>
        </div>
      </a>

      <!-- Programmation -->
      <a
        href="/services/programmation"
        class="group relative rounded-3xl border border-white/10 bg-base-200/40 backdrop-blur-xl p-7 md:p-8
               hover:border-white/20 hover:bg-base-200/55 transition"
      >
        <div class="absolute inset-0 rounded-3xl opacity-0 group-hover:opacity-100 transition
                    bg-gradient-to-r from-secondary/12 via-primary/10 to-accent/12"></div>

        <div class="relative">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="grid place-items-center h-12 w-12 rounded-2xl border border-white/10 bg-base-300/40">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="opacity-90">
                  <path d="M7 7h10v10H7V7z" stroke="currentColor" stroke-width="2" />
                  <path d="M4 12h3M17 12h3M12 4v3M12 17v3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <div class="text-sm text-white/60 font-medium">02 — Programmation</div>
                <div class="text-xl font-bold">ECU & modules</div>
              </div>
            </div>

            <span class="badge badge-outline border-white/20 text-white/70">Sécurisé</span>
          </div>

          <p class="mt-5 text-white/70 leading-relaxed">
            Codage, adaptations, reprogrammation et mises à jour avec validation post-op.
          </p>

          <ul class="mt-6 space-y-2 text-sm text-white/65">
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-secondary"></span>
              Procédure + sauvegarde
            </li>
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
              Vérification après intervention
            </li>
          </ul>

          <div class="mt-7 inline-flex items-center gap-2 font-semibold text-primary">
            En savoir plus
            <span class="transition group-hover:translate-x-1">→</span>
          </div>
        </div>
      </a>

      <!-- Réparation -->
      <a
        href="/services/reparation"
        class="group relative rounded-3xl border border-white/10 bg-base-200/40 backdrop-blur-xl p-7 md:p-8
               hover:border-white/20 hover:bg-base-200/55 transition"
      >
        <div class="absolute inset-0 rounded-3xl opacity-0 group-hover:opacity-100 transition
                    bg-gradient-to-r from-accent/12 via-secondary/10 to-primary/12"></div>

        <div class="relative">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="grid place-items-center h-12 w-12 rounded-2xl border border-white/10 bg-base-300/40">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="opacity-90">
                  <path d="M9 3v5l-2 2 6 6 2-2h5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M7 10l-4 4 7 7 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <div class="text-sm text-white/60 font-medium">03 — Réparation</div>
                <div class="text-xl font-bold">Fiable & durable</div>
              </div>
            </div>

            <span class="badge badge-outline border-white/20 text-white/70">Contrôlé</span>
          </div>

          <p class="mt-5 text-white/70 leading-relaxed">
            Réparation électronique avec contrôles, tests et restitution fiable dans le temps.
          </p>

          <ul class="mt-6 space-y-2 text-sm text-white/65">
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              Tests avant / après
            </li>
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-secondary"></span>
              Objectif long terme
            </li>
          </ul>

          <div class="mt-7 inline-flex items-center gap-2 font-semibold text-primary">
            En savoir plus
            <span class="transition group-hover:translate-x-1">→</span>
          </div>
        </div>
      </a>
    </div>

    <!-- PROOF ROW (remplit le bas de section) -->
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      <div class="proof-tile">
        <div class="proof-title">Mesures & lecture ECU</div>
        <div class="proof-desc">Pas d’approximation : contrôles ciblés et traçables.</div>
      </div>
      <div class="proof-tile">
        <div class="proof-title">Codage sécurisé</div>
        <div class="proof-desc">Sauvegarde + procédure maîtrisée avant toute écriture.</div>
      </div>
      <div class="proof-tile">
        <div class="proof-title">Tests avant / après</div>
        <div class="proof-desc">Validation post-intervention avant restitution.</div>
      </div>
    </div>

    <div class="mt-14 text-center">
      <a href="/contact" class="btn btn-primary btn-lg shadow-lg shadow-primary/25">
        Parler de votre besoin
      </a>
      <div class="mt-4 text-sm text-white/60">
        Réponse rapide • Devis clair • Intervention maîtrisée
      </div>
    </div>
  </div>

  <style>
    .process-pill{
      display:flex;
      align-items:center;
      gap:.6rem;
      padding:.65rem 1rem;
      border-radius:9999px;
      border:1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.04);
      backdrop-filter: blur(10px);
      color: rgba(255,255,255,.78);
      font-size:.95rem;
    }
    .process-n{
      height:28px;
      width:28px;
      display:grid;
      place-items:center;
      border-radius:9999px;
      background: rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.12);
      font-weight:700;
      color: rgba(255,255,255,.9);
    }
    .process-line{
      height:1px;
      width:60px;
      background: linear-gradient(to right, transparent, rgba(255,255,255,.25), transparent);
      opacity:.7;
    }

    .proof-tile{
      border:1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
      border-radius: 20px;
      padding: 16px 18px;
      backdrop-filter: blur(10px);
    }
    .proof-title{
      font-weight: 700;
      color: rgba(255,255,255,.88);
      margin-bottom: 6px;
    }
    .proof-desc{
      color: rgba(255,255,255,.62);
      font-size: .95rem;
      line-height: 1.5;
    }
  </style>
</section>

<section class="relative isolate overflow-hidden py-32">
  <!-- BACKGROUND (toujours visible) -->
  <div class="absolute inset-0 z-0">
    <img
      src="/assets/brand/bg-atelier.jpg"
      alt=""
      class="w-full h-full object-cover scale-[1.04]"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- OVERLAY CINÉMA (au-dessus de l’image) -->
  <div class="absolute inset-0 z-10 bg-black/60"></div>
  <div class="absolute inset-0 z-10 bg-gradient-to-b from-black/30 via-black/60 to-black/80"></div>

  <!-- AMBIANCE (très subtil, au-dessus aussi) -->
  <div
    class="absolute inset-0 z-10 pointer-events-none
           bg-[radial-gradient(700px_420px_at_30%_40%,rgba(139,92,246,0.16),transparent_60%)]
           opacity-90"
  ></div>

  <!-- CONTENU (au-dessus de tout) -->
  <div class="relative z-20">
    <div class="max-w-6xl mx-auto px-6">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <!-- COLONNE TEXTE -->
        <div>
          <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
            <span class="h-2 w-2 rounded-full bg-success"></span>
            Pourquoi nous
          </div>

          <h2 class="mt-8 text-4xl md:text-5xl font-bold leading-tight">
            Une méthode <span class="text-primary">rigoureuse</span>, pas de l’improvisation.
          </h2>

          <p class="mt-6 text-white/70 leading-relaxed max-w-lg">
            Chaque intervention suit un protocole clair : analyse précise, sécurisation des données,
            exécution maîtrisée et validation complète. Nous privilégions la fiabilité long terme.
          </p>

          <div class="mt-10">
            <a href="/contact" class="btn btn-primary btn-lg shadow-lg shadow-primary/25">
              Discuter de votre véhicule
            </a>
          </div>
        </div>

        <!-- COLONNE MÉTHODE -->
        <div class="relative">
          <div class="absolute left-4 top-0 bottom-0 w-px bg-gradient-to-b from-primary/50 via-white/10 to-transparent"></div>

          <div class="space-y-10 pl-12">
            <div class="why-step">
              <div class="text-primary font-semibold tracking-wide">01</div>
              <div class="text-xl font-semibold mt-2">Diagnostic mesuré</div>
              <p class="mt-2 text-white/60 text-sm leading-relaxed">
                Lecture défauts, contrôles ciblés, analyse capteurs et réseau CAN. Cause réelle, pas le symptôme.
              </p>
            </div>

            <div class="why-step">
              <div class="text-primary font-semibold tracking-wide">02</div>
              <div class="text-xl font-semibold mt-2">Intervention sécurisée</div>
              <p class="mt-2 text-white/60 text-sm leading-relaxed">
                Sauvegarde ECU avant toute écriture. Procédure maîtrisée, environnement contrôlé.
              </p>
            </div>

            <div class="why-step">
              <div class="text-primary font-semibold tracking-wide">03</div>
              <div class="text-xl font-semibold mt-2">Validation & restitution</div>
              <p class="mt-2 text-white/60 text-sm leading-relaxed">
                Tests avant / après. Explication claire + recommandations adaptées.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <style>
      .why-step{ position: relative; padding: 4px 0; }
      .why-step::before{
        content:"";
        position:absolute;
        left:-34px;
        top:10px;
        width:10px; height:10px;
        border-radius:999px;
        background: rgba(139,92,246,.95);
        box-shadow: 0 0 0 6px rgba(139,92,246,.16);
      }
    </style>
  </div>
</section>


{/* =========================
   GOOGLE REVIEWS – HORIZONTAL PREMIUM (scroll + arrows + progress + drag)
========================= */}
<section class="relative overflow-hidden py-28">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-32 left-1/2 h-80 w-[65rem] -translate-x-1/2 rounded-full blur-3xl opacity-10 bg-gradient-to-r from-primary via-accent to-secondary"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4">
    <ScrollReveal>
      <div class="text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
          <span class="h-2 w-2 rounded-full bg-success"></span>
          Avis clients
        </div>

        <h2 class="mt-6 text-4xl md:text-5xl font-bold tracking-tight">
          Ils nous font confiance
        </h2>

        <p class="mt-4 text-white/70 max-w-2xl mx-auto leading-relaxed">
          Des avis authentiques laissés sur Google par nos clients.
        </p>

        <div class="mt-6 inline-flex items-center gap-4 rounded-2xl border border-white/10 bg-base-200/30 backdrop-blur px-6 py-4">
          <div class="text-3xl font-bold">4.9</div>
          <div class="text-left">
            <div class="text-white/80 text-sm">Note moyenne Google</div>
            <div class="text-white/55 text-xs">Basé sur de nombreux avis 5 étoiles</div>
          </div>

          <div class="stars ml-1 flex items-center gap-1 text-yellow-400 text-lg">
            <span class="star">★</span><span class="star">★</span><span class="star">★</span><span class="star">★</span><span class="star">★</span>
          </div>
        </div>
      </div>
    </ScrollReveal>

    <ScrollReveal delay={120}>
      <div class="relative mt-14">
        {/* FLÈCHES */}
        <button
          type="button"
          class="reviews-arrow reviews-arrow--left"
          aria-label="Avis précédents"
          data-reviews-prev
        >
          ←
        </button>

        <button
          type="button"
          class="reviews-arrow reviews-arrow--right"
          aria-label="Avis suivants"
          data-reviews-next
        >
          →
        </button>

        {/* Fade edges */}
        <div class="pointer-events-none absolute inset-y-0 left-0 w-16 bg-gradient-to-r from-base-100/95 to-transparent z-10"></div>
        <div class="pointer-events-none absolute inset-y-0 right-0 w-16 bg-gradient-to-l from-base-100/95 to-transparent z-10"></div>

        {/* TRACK */}
        <div
          class="reviews-carousel"
          data-reviews-track
          aria-label="Avis Google"
        >
          {[
            {
              name: "Mounir B.",
              text: "J’ai été refaire une duplication de clé. Très satisfait et par la même occasion j’ai fait un stage 1 de ma Peugeot 308… Je recommande les yeux fermés !",
            },
            {
              name: "Gor A.",
              text: "Problème de calculateur sur ma BMW 330e, réglé en une seule après-midi. Travail très professionnel, rapide et soigné… Je recommande vivement !",
            },
            {
              name: "Firas B.",
              text: "Intervention sur ma BMW E46. Correction électronique du pot catalytique. Service compétent avec un prix raisonnable et un délai compétitif.",
            },
            {
              name: "Jacques P.",
              text: "Problème AdBlue sur mon Discovery + augmentation puissance… Professionnalisme rare en électronique automobile. Je recommande à 1000%.",
            },
            {
              name: "Yassine A.",
              text: "Top du top les deux frères ! RSQ3 stage 2… Réparation boîtier CASS… Ils maîtrisent beaucoup leur domaine. Merci encore. Je recommande.",
            },
            {
              name: "Jose C.",
              text: "Très belle expérience chez Auto Softronics. Correction ACC et problème de boîtier de son… Très bonne maîtrise. À bientôt.",
            },
          ].map((r) => (
            <article class="review-card">
              <div class="sweep absolute inset-0 rounded-3xl pointer-events-none"></div>

              <div class="relative">
                <div class="flex items-center justify-between gap-3">
                  <div class="text-white/90 font-semibold">{r.name}</div>
                  <div class="stars stars--small flex items-center gap-1 text-yellow-400 text-sm">
                    <span class="star">★</span><span class="star">★</span><span class="star">★</span><span class="star">★</span><span class="star">★</span>
                  </div>
                </div>

                <p class="mt-4 text-sm text-white/65 leading-relaxed">
                  {r.text}
                </p>

                <div class="mt-6 text-xs text-white/45">
                  Source : Google Reviews
                </div>
              </div>
            </article>
          ))}
        </div>

        {/* PROGRESS */}
        <div class="mt-6 flex justify-center">
          <div class="reviews-progress" aria-hidden="true">
            <div class="reviews-progress__bar" data-reviews-progress></div>
          </div>
        </div>

        <div class="mt-4 text-center text-sm text-white/55">
          Faites défiler → pour voir plus d’avis
        </div>
      </div>
    </ScrollReveal>

    <div class="mt-10 flex justify-center">
      <a
        href="https://www.google.com/search?sa=X&sca_esv=4c08c6716f6b357b&hl=fr-BE&biw=1920&bih=953&sxsrf=ANbL-n4TJP4WaG4Y8-RBMVR73ZJVHV0Z4g:1772404235432&q=Auto%20Softronics%20Avis&rflfq=1&num=20&stick=H4sIAAAAAAAAAONgkxI2tbQ0NrK0sDA1NjcwMzGwNDI33MDI-IpRxLG0JF8hOD-tpCg_LzO5WMGxLLN4EStWYQBBuMTPSAAAAA&rldimm=5993298853706409271&tbm=lcl&ved=0CEgQ5foLahcKEwi4-pia7_-SAxUAAAAAHQAAAAAQCg#arid=Ci9DQUlRQUNvZENodHljRjlvT2xGTFVUaFpjalpMYkVWYVQzRTVkVjlaWmtZdFRGRRAB&lkt=LocalPoiReviews&rlfi=hd:;si:5993298853706409271,l,ChRBdXRvIFNvZnRyb25pY3MgQXZpc0iw3Z2YhruAgAhaHBACGAAYASIUYXV0byBzb2Z0cm9uaWNzIGF2aXOSAQpjYXJfcmVwYWlymgFEQ2k5RFFVbFJRVU52WkVOb2RIbGpSamx2VDJ0b1ZsUklWbEJhYkZac1kyNW9RbFJJWnpGWmJVWTBVakI0YWxsdVl4QUL6AQUImAQQMg;mv:[[50.420949477319034,4.475156874822501],[50.42058952268097,4.474591925177499]]"
        target="_blank"
        rel="noreferrer"
        class="btn btn-outline btn-lg border-white/25 text-white hover:bg-white/10 hover:border-primary transition"
      >
        Voir tous les avis sur Google
      </a>
    </div>
  </div>

  <style>
    /* ============ CAROUSEL ============ */
    .reviews-carousel{
      display: flex;
      gap: 18px;
      overflow-x: auto;
      padding: 2px 4px 14px;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      cursor: grab;
      user-select: none;
    }
    .reviews-carousel:active{ cursor: grabbing; }

    /* largeur lisible (FIN du texte en colonne) */
    .review-card{
      position: relative;
      flex: 0 0 auto;
      width: 560px;              /* desktop */
      max-width: 86vw;           /* mobile */
      scroll-snap-align: start;
      border-radius: 24px;
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(20,20,28,.35);
      backdrop-filter: blur(14px);
      padding: 26px;
      overflow: hidden;
      transition: transform .35s ease, border-color .35s ease;
    }
    @media (min-width: 1024px){
      .review-card{ width: 520px; }
    }
    .review-card:hover{
      transform: translateY(-4px);
      border-color: rgba(255,255,255,.25);
    }

    /* scrollbar discret */
    .reviews-carousel::-webkit-scrollbar{ height: 10px; }
    .reviews-carousel::-webkit-scrollbar-track{ background: rgba(255,255,255,.06); border-radius: 999px; }
    .reviews-carousel::-webkit-scrollbar-thumb{ background: rgba(255,255,255,.14); border-radius: 999px; }
    .reviews-carousel{ scrollbar-color: rgba(255,255,255,.18) rgba(255,255,255,.06); }

    /* ============ FLÈCHES ============ */
    .reviews-arrow{
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 20;
      height: 44px;
      width: 44px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,.14);
      background: rgba(10,10,14,.55);
      color: rgba(255,255,255,.9);
      backdrop-filter: blur(10px);
      display: grid;
      place-items: center;
      transition: transform .25s ease, background .25s ease, border-color .25s ease, opacity .25s ease;
      opacity: .9;
    }
    .reviews-arrow:hover{
      background: rgba(10,10,14,.75);
      border-color: rgba(255,255,255,.24);
      transform: translateY(-50%) scale(1.06);
      opacity: 1;
    }
    .reviews-arrow--left{ left: -6px; }
    .reviews-arrow--right{ right: -6px; }

    /* mobile: flèches un peu plus discrètes */
    @media (max-width: 640px){
      .reviews-arrow{ display:none; }
    }

    /* ============ PROGRESS BAR ============ */
    .reviews-progress{
      width: min(520px, 90vw);
      height: 6px;
      border-radius: 999px;
      background: rgba(255,255,255,.08);
      overflow: hidden;
      border: 1px solid rgba(255,255,255,.10);
    }
    .reviews-progress__bar{
      height: 100%;
      width: 0%;
      background: linear-gradient(90deg, rgba(139,92,246,.65), rgba(99,102,241,.55));
      border-radius: 999px;
      transition: width .12s linear;
    }

    /* ============ LIGHT SWEEP ============ */
    .review-card .sweep::before{
      content:"";
      position:absolute; inset:-40%;
      background: linear-gradient(115deg, transparent 45%, rgba(255,255,255,.08) 50%, transparent 55%);
      transform: translateX(-30%) rotate(8deg);
      opacity: 0;
      transition: transform .6s ease, opacity .6s ease;
    }
    .review-card:hover .sweep::before{
      opacity: 1;
      transform: translateX(30%) rotate(8deg);
    }

    /* ============ STARS (subtil) ============ */
    .stars .star{
      display:inline-block;
      animation: starPulse 3.8s ease-in-out infinite;
      opacity: .95;
    }
    .stars .star:nth-child(2){ animation-delay: .12s; }
    .stars .star:nth-child(3){ animation-delay: .24s; }
    .stars .star:nth-child(4){ animation-delay: .36s; }
    .stars .star:nth-child(5){ animation-delay: .48s; }

    .stars--small .star{ animation-duration: 4.4s; opacity: .9; }

    @keyframes starPulse{
      0%, 100% { transform: translateY(0) scale(1); filter: drop-shadow(0 0 0 rgba(0,0,0,0)); }
      50% { transform: translateY(-1px) scale(1.03); filter: drop-shadow(0 0 10px rgba(250,204,21,.16)); }
    }

    @media (prefers-reduced-motion: reduce){
      .stars .star{ animation: none; }
      .review-card, .review-card .sweep::before, .reviews-arrow{ transition: none; }
      .review-card:hover{ transform: none; }
      .reviews-carousel{ scroll-behavior: auto; }
      .reviews-progress__bar{ transition: none; }
    }
  </style>

  {/* JS ultra léger : flèches + progress + drag */}
  <script is:inline>
    (() => {
      const track = document.querySelector('[data-reviews-track]');
      const prev = document.querySelector('[data-reviews-prev]');
      const next = document.querySelector('[data-reviews-next]');
      const bar  = document.querySelector('[data-reviews-progress]');
      if (!track) return;

      const card = track.querySelector('.review-card');
      const step = () => {
        if (!card) return 520;
        const styles = getComputedStyle(track);
        const gap = parseFloat(styles.columnGap || styles.gap || '18') || 18;
        return card.getBoundingClientRect().width + gap;
      };

      const updateProgress = () => {
        if (!bar) return;
        const max = track.scrollWidth - track.clientWidth;
        const pct = max <= 0 ? 0 : (track.scrollLeft / max) * 100;
        bar.style.width = `${Math.max(0, Math.min(100, pct))}%`;
      };

      prev && prev.addEventListener('click', () => track.scrollBy({ left: -step(), behavior: 'smooth' }));
      next && next.addEventListener('click', () => track.scrollBy({ left:  step(), behavior: 'smooth' }));

      track.addEventListener('scroll', updateProgress, { passive: true });
      window.addEventListener('resize', updateProgress);
      updateProgress();

      // Drag (desktop) : très léger
      let isDown = false;
      let startX = 0;
      let startLeft = 0;

      track.addEventListener('pointerdown', (e) => {
        isDown = true;
        startX = e.clientX;
        startLeft = track.scrollLeft;
        track.setPointerCapture(e.pointerId);
      });

      track.addEventListener('pointermove', (e) => {
        if (!isDown) return;
        const dx = e.clientX - startX;
        track.scrollLeft = startLeft - dx;
      });

      const end = () => { isDown = false; };
      track.addEventListener('pointerup', end);
      track.addEventListener('pointercancel', end);
      track.addEventListener('pointerleave', end);
    })();
  </script>
</section>





