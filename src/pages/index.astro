---
import BaseLayout from "../layouts/BaseLayout.astro";
import HeroPremium from "../components/HeroPremium.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
  const brand = [
    { name: "Audi", src: "/assets/brand/Audi.png" },
    { name: "BMW", src: "/assets/brand/Bmw.png" },
    { name: "Mercedes", src: "/assets/brand/Mercedes.png" },
    { name: "Volkswagen", src: "/assets/brand/Volkswagen.png" },
    { name: "Peugeot", src: "/assets/brand/Peugeot.png" },
    { name: "Renault", src: "/assets/brand/Renault.png" },
    { name: "Citroën", src: "/assets/brand/Citroen.png" },
    { name: "Ford", src: "/assets/brand/Ford.png" },
    { name: "Opel", src: "/assets/brand/Opel.png" },
    { name: "Toyota", src: "/assets/brand/Toyota.png" },
    { name: "Nissan", src: "/assets/brand/Nissan.png" },
    { name: "Hyundai", src: "/assets/brand/Hyundai.png" },
  ];
---

<BaseLayout
  title="Autosoftronics | Diagnostic, Programmation, Réparation"
  description="Diagnostic précis, programmation et réparation automobile."
>
  <!-- HERO PREMIUM -->
  <HeroPremium />

  <!-- APPLE STICKY SECTION -->
 

  <!-- SERVICES PREMIUM -->
  <section class="relative overflow-hidden py-28">
  <!-- CINEMA BACKGROUND (no PNG) -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <!-- aurora glows -->
    <div class="absolute -top-32 left-1/2 h-80 w-[70rem] -translate-x-1/2 rounded-full blur-3xl opacity-20 bg-gradient-to-r from-primary via-accent to-secondary"></div>
    <div class="absolute -bottom-40 left-1/2 h-80 w-[70rem] -translate-x-1/2 rounded-full blur-3xl opacity-15 bg-gradient-to-r from-secondary via-primary to-accent"></div>

    <!-- vignette cinema -->
    <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_center,transparent_35%,rgba(0,0,0,.70)_100%)]"></div>

    <!-- subtle dot texture (lighter than before) -->
    <div class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(circle_at_1px_1px,white_1px,transparent_1px)] [background-size:22px_22px]"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
        <span class="h-2 w-2 rounded-full bg-success"></span>
        Prestations principales
      </div>

      <h2 class="mt-6 text-4xl md:text-5xl font-bold tracking-tight">
        Nos services
      </h2>

      <p class="mt-4 text-white/70 max-w-2xl mx-auto leading-relaxed">
        Une méthode claire : diagnostic précis, intervention adaptée, validation avant restitution.
      </p>

      <!-- PROCESS STRIP (remplit + ultra pro) -->
      <div class="mt-10 flex flex-col md:flex-row items-center justify-center gap-3">
        <div class="process-pill">
          <span class="process-n">1</span>
          <span>Diagnostic précis</span>
        </div>
        <div class="process-line hidden md:block"></div>
        <div class="process-pill">
          <span class="process-n">2</span>
          <span>Intervention adaptée</span>
        </div>
        <div class="process-line hidden md:block"></div>
        <div class="process-pill">
          <span class="process-n">3</span>
          <span>Validation & restitution</span>
        </div>
      </div>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      <!-- Diagnostic -->
      <a
        href="/services/diagnostic"
        class="group relative rounded-3xl border border-white/10 bg-base-200/40 backdrop-blur-xl p-7 md:p-8
               hover:border-white/20 hover:bg-base-200/55 transition"
      >
        <div class="absolute inset-0 rounded-3xl opacity-0 group-hover:opacity-100 transition
                    bg-gradient-to-r from-primary/12 via-accent/10 to-secondary/12"></div>

        <div class="relative">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="grid place-items-center h-12 w-12 rounded-2xl border border-white/10 bg-base-300/40">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="opacity-90">
                  <path d="M10 4h4M9 8h6M8 12h8M7 16h10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                  <path d="M6 20h12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <div class="text-sm text-white/60 font-medium">01 — Diagnostic</div>
                <div class="text-xl font-bold">Identifier la panne</div>
              </div>
            </div>

            <span class="badge badge-outline border-white/20 text-white/70">Rapide</span>
          </div>

          <p class="mt-5 text-white/70 leading-relaxed">
            Lecture défauts, tests ciblés, analyse capteurs/actionneurs et réseau CAN.
          </p>

          <ul class="mt-6 space-y-2 text-sm text-white/65">
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
              Rapport clair & recommandations
            </li>
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              Contrôles mesurés, pas d’approximation
            </li>
          </ul>

          <div class="mt-7 inline-flex items-center gap-2 font-semibold text-primary">
            En savoir plus
            <span class="transition group-hover:translate-x-1">→</span>
          </div>
        </div>
      </a>

      <!-- Programmation -->
      <a
        href="/services/programmation"
        class="group relative rounded-3xl border border-white/10 bg-base-200/40 backdrop-blur-xl p-7 md:p-8
               hover:border-white/20 hover:bg-base-200/55 transition"
      >
        <div class="absolute inset-0 rounded-3xl opacity-0 group-hover:opacity-100 transition
                    bg-gradient-to-r from-secondary/12 via-primary/10 to-accent/12"></div>

        <div class="relative">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="grid place-items-center h-12 w-12 rounded-2xl border border-white/10 bg-base-300/40">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="opacity-90">
                  <path d="M7 7h10v10H7V7z" stroke="currentColor" stroke-width="2" />
                  <path d="M4 12h3M17 12h3M12 4v3M12 17v3" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                </svg>
              </div>
              <div>
                <div class="text-sm text-white/60 font-medium">02 — Programmation</div>
                <div class="text-xl font-bold">Modules & système</div>
              </div>
            </div>

            <span class="badge badge-outline border-white/20 text-white/70">Sécurisé</span>
          </div>

          <p class="mt-5 text-white/70 leading-relaxed">
            Codage, adaptations, reprogrammation et mises à jour avec validation post-op.
          </p>

          <ul class="mt-6 space-y-2 text-sm text-white/65">
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-secondary"></span>
              Procédure + sauvegarde
            </li>
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
              Vérification après intervention
            </li>
          </ul>

          <div class="mt-7 inline-flex items-center gap-2 font-semibold text-primary">
            En savoir plus
            <span class="transition group-hover:translate-x-1">→</span>
          </div>
        </div>
      </a>

      <!-- Réparation -->
      <a
        href="/services/reparation"
        class="group relative rounded-3xl border border-white/10 bg-base-200/40 backdrop-blur-xl p-7 md:p-8
               hover:border-white/20 hover:bg-base-200/55 transition"
      >
        <div class="absolute inset-0 rounded-3xl opacity-0 group-hover:opacity-100 transition
                    bg-gradient-to-r from-accent/12 via-secondary/10 to-primary/12"></div>

        <div class="relative">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="grid place-items-center h-12 w-12 rounded-2xl border border-white/10 bg-base-300/40">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" class="opacity-90">
                  <path d="M9 3v5l-2 2 6 6 2-2h5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  <path d="M7 10l-4 4 7 7 4-4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div>
                <div class="text-sm text-white/60 font-medium">03 — Réparation</div>
                <div class="text-xl font-bold">Fiable & durable</div>
              </div>
            </div>

            <span class="badge badge-outline border-white/20 text-white/70">Contrôlé</span>
          </div>

          <p class="mt-5 text-white/70 leading-relaxed">
            Réparation électronique avec contrôles, tests et restitution fiable dans le temps.
          </p>

          <ul class="mt-6 space-y-2 text-sm text-white/65">
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
              Tests avant / après
            </li>
            <li class="flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-secondary"></span>
              Objectif long terme
            </li>
          </ul>

          <div class="mt-7 inline-flex items-center gap-2 font-semibold text-primary">
            En savoir plus
            <span class="transition group-hover:translate-x-1">→</span>
          </div>
        </div>
      </a>
    </div>

    <!-- PROOF ROW (remplit le bas de section) -->
    <div class="mt-10 grid gap-4 md:grid-cols-3">
      <div class="proof-tile">
        <div class="proof-title">Mesures & lecture ECU</div>
        <div class="proof-desc">Pas d’approximation : contrôles ciblés et traçables.</div>
      </div>
      <div class="proof-tile">
        <div class="proof-title">Codage sécurisé</div>
        <div class="proof-desc">Sauvegarde + procédure maîtrisée avant toute écriture.</div>
      </div>
      <div class="proof-tile">
        <div class="proof-title">Tests avant / après</div>
        <div class="proof-desc">Validation post-intervention avant restitution.</div>
      </div>
    </div>

    <div class="mt-14 text-center">
      <a href="/contact" class="btn btn-primary btn-lg shadow-lg shadow-primary/25">
        Parler de votre besoin
      </a>
      <div class="mt-4 text-sm text-white/60">
        Réponse rapide • Devis clair • Intervention maîtrisée
      </div>
    </div>
  </div>

  <style>
    .process-pill{
      display:flex;
      align-items:center;
      gap:.6rem;
      padding:.65rem 1rem;
      border-radius:9999px;
      border:1px solid rgba(255,255,255,.12);
      background: rgba(255,255,255,.04);
      backdrop-filter: blur(10px);
      color: rgba(255,255,255,.78);
      font-size:.95rem;
    }
    .process-n{
      height:28px;
      width:28px;
      display:grid;
      place-items:center;
      border-radius:9999px;
      background: rgba(255,255,255,.06);
      border:1px solid rgba(255,255,255,.12);
      font-weight:700;
      color: rgba(255,255,255,.9);
    }
    .process-line{
      height:1px;
      width:60px;
      background: linear-gradient(to right, transparent, rgba(255,255,255,.25), transparent);
      opacity:.7;
    }

    .proof-tile{
      border:1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.03);
      border-radius: 20px;
      padding: 16px 18px;
      backdrop-filter: blur(10px);
    }
    .proof-title{
      font-weight: 700;
      color: rgba(255,255,255,.88);
      margin-bottom: 6px;
    }
    .proof-desc{
      color: rgba(255,255,255,.62);
      font-size: .95rem;
      line-height: 1.5;
    }
  </style>
</section>

<section class="relative isolate overflow-hidden py-32">
  <!-- BACKGROUND (toujours visible) -->
  <div class="absolute inset-0 z-0">
    <img
      src="/assets/brand/bg-atelier.jpg"
      alt=""
      class="w-full h-full object-cover scale-[1.04]"
      loading="lazy"
      decoding="async"
    />
  </div>

  <!-- OVERLAY CINÉMA (au-dessus de l’image) -->
  <div class="absolute inset-0 z-10 bg-black/5"></div>
  <div class="absolute inset-0 z-10 bg-gradient-to-b from-black/30 via-black/60 to-black/80"></div>

  <!-- AMBIANCE (très subtil, au-dessus aussi) -->
  <div
    class="absolute inset-0 z-10 pointer-events-none
           bg-[radial-gradient(700px_420px_at_30%_40%,rgba(139,92,246,0.16),transparent_60%)]
           opacity-90"
  ></div>

  <!-- CONTENU (au-dessus de tout) -->
<div class="relative z-20">
  <div class="max-w-6xl mx-auto px-6">
    <div class="grid lg:grid-cols-2 gap-20 items-center">
      <!-- COLONNE TEXTE -->
      <div>
        <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
          <span class="h-2 w-2 rounded-full bg-success"></span>
          Pourquoi nous
        </div>

        <h2 class="mt-8 text-4xl md:text-5xl font-bold leading-tight">
          Une méthode <span class="text-primary">rigoureuse</span>, pas de l’improvisation.
        </h2>

        <p class="mt-6 text-white/70 leading-relaxed max-w-xl text-lg">
          Chaque intervention suit un protocole clair : analyse précise, sécurisation des données,
          exécution maîtrisée et validation complète. Nous privilégions la fiabilité long terme.
        </p>

        <div class="mt-10">
          <a href="/contact" class="btn btn-primary btn-lg shadow-lg shadow-primary/25">
            Discuter de votre véhicule
          </a>
        </div>

        <div class="mt-5 text-sm text-white/50">
          Diagnostic précis • Procédure sécurisée • Validation finale
        </div>
      </div>

      <!-- COLONNE MÉTHODE -->
      <div>
        <div class="space-y-12">
          <div class="why-step-premium">
            <div class="why-step-premium__rail">
              <span class="why-step-premium__dot"></span>
              <span class="why-step-premium__line"></span>
            </div>

            <div class="why-step-premium__content">
              <div class="why-step-premium__top">
                <span class="why-step-premium__num">01</span>
                <h3 class="why-step-premium__title">Diagnostic mesuré</h3>
              </div>
              <p class="why-step-premium__text">
                Lecture défauts, contrôles ciblés, analyse capteurs et réseau CAN. Cause réelle, pas le symptôme.
              </p>
            </div>
          </div>

          <div class="why-step-premium">
            <div class="why-step-premium__rail">
              <span class="why-step-premium__dot"></span>
              <span class="why-step-premium__line"></span>
            </div>

            <div class="why-step-premium__content">
              <div class="why-step-premium__top">
                <span class="why-step-premium__num">02</span>
                <h3 class="why-step-premium__title">Intervention sécurisée</h3>
              </div>
              <p class="why-step-premium__text">
                Sauvegarde ECU avant toute écriture. Procédure maîtrisée, environnement contrôlé.
              </p>
            </div>
          </div>

          <div class="why-step-premium">
            <div class="why-step-premium__rail">
              <span class="why-step-premium__dot"></span>
            </div>

            <div class="why-step-premium__content">
              <div class="why-step-premium__top">
                <span class="why-step-premium__num">03</span>
                <h3 class="why-step-premium__title">Validation & restitution</h3>
              </div>
              <p class="why-step-premium__text">
                Tests avant / après. Explication claire + recommandations adaptées.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <style>
    .why-step-premium::before,
    .why-step-premium::after{
      content: none !important;
      display: none !important;
    }

    .why-step-premium{
      display: flex;
      gap: 24px;
      align-items: flex-start;
      padding: 10px 0;
      border-radius: 20px;
      transition: transform .28s ease, background .28s ease;
    }

    .why-step-premium:hover{
      transform: translateX(2px);
      background: linear-gradient(
        90deg,
        rgba(255,255,255,.03),
        rgba(255,255,255,0)
      );
    }

    .why-step-premium__rail{
      width: 28px;
      display: flex;
      flex-direction: column;
      align-items: center;
      flex: 0 0 28px;
      padding-top: 10px;
    }

    .why-step-premium__dot{
      width: 11px;
      height: 11px;
      border-radius: 9999px;
      background: rgba(139,92,246,.95);
      box-shadow:
        0 0 0 8px rgba(139,92,246,.10),
        0 0 16px rgba(139,92,246,.22);
      flex: 0 0 auto;
      transition: transform .28s ease, box-shadow .28s ease, background .28s ease;
    }

    .why-step-premium:hover .why-step-premium__dot{
      transform: scale(1.06);
      box-shadow:
        0 0 0 10px rgba(139,92,246,.12),
        0 0 22px rgba(139,92,246,.30);
    }

    .why-step-premium__line{
      width: 1px;
      flex: 1 1 auto;
      margin-top: 14px;
      min-height: 82px;
      background: linear-gradient(
        to bottom,
        rgba(139,92,246,.42),
        rgba(255,255,255,.08),
        rgba(255,255,255,0)
      );
      opacity: .9;
      transition: opacity .28s ease;
    }

    .why-step-premium:hover .why-step-premium__line{
      opacity: 1;
    }

    .why-step-premium__content{
      flex: 1 1 auto;
      min-width: 0;
    }

    .why-step-premium__top{
      display: flex;
      align-items: center;
      gap: 18px;
    }

    .why-step-premium__num{
      font-size: 30px;
      line-height: 1;
      font-weight: 700;
      color: rgba(139,92,246,.95);
      letter-spacing: .02em;
      min-width: 54px;
      transition: color .28s ease, transform .28s ease;
    }

    .why-step-premium:hover .why-step-premium__num{
      transform: translateX(1px);
    }

    .why-step-premium__title{
      margin: 0;
      font-size: 22px;
      line-height: 1.2;
      font-weight: 700;
      color: white;
      transition: color .28s ease;
    }

    .why-step-premium:hover .why-step-premium__title{
      color: rgba(255,255,255,.98);
    }

    .why-step-premium__text{
      margin-top: 14px;
      color: rgba(255,255,255,.66);
      line-height: 1.85;
      font-size: 15px;
      max-width: 32rem;
    }

    @media (max-width: 768px){
      .why-step-premium{
        gap: 18px;
        padding: 6px 0;
      }

      .why-step-premium__rail{
        width: 24px;
        flex: 0 0 24px;
      }

      .why-step-premium__num{
        font-size: 24px;
        min-width: 40px;
      }

      .why-step-premium__title{
        font-size: 19px;
      }

      .why-step-premium__text{
        font-size: 14px;
        line-height: 1.7;
      }

      .why-step-premium__line{
        min-height: 70px;
      }
    }

    @media (prefers-reduced-motion: reduce){
      .why-step-premium,
      .why-step-premium__dot,
      .why-step-premium__line,
      .why-step-premium__num,
      .why-step-premium__title{
        transition: none !important;
      }

      .why-step-premium:hover{
        transform: none;
      }
    }
  </style>
  </div>
</section>


{/* =========================
   GOOGLE REVIEWS – HORIZONTAL PREMIUM (scroll + arrows + progress + drag)
========================= */}
<section class="relative overflow-hidden py-28">
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="absolute -top-32 left-1/2 h-80 w-[65rem] -translate-x-1/2 rounded-full blur-3xl opacity-10 bg-gradient-to-r from-primary via-accent to-secondary"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4">
    <ScrollReveal>
      <div class="text-center">
        <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
          <span class="h-2 w-2 rounded-full bg-success"></span>
          Avis clients
        </div>

        <h2 class="mt-6 text-4xl md:text-5xl font-bold tracking-tight">
          Ils nous font confiance
        </h2>

        <p class="mt-4 text-white/70 max-w-2xl mx-auto leading-relaxed">
          Des avis authentiques laissés sur Google par nos clients.
        </p>

        <div class="mt-6 inline-flex items-center gap-4 rounded-2xl border border-white/10 bg-base-200/30 backdrop-blur px-6 py-4">
          <div class="text-3xl font-bold">4.9</div>
          <div class="text-left">
            <div class="text-white/80 text-sm">Note moyenne Google</div>
            <div class="text-white/55 text-xs">Basé sur de nombreux avis 5 étoiles</div>
          </div>

          <div class="stars ml-1 flex items-center gap-1 text-yellow-400 text-lg">
            <span class="star">★</span><span class="star">★</span><span class="star">★</span><span class="star">★</span><span class="star">★</span>
          </div>
        </div>
      </div>
    </ScrollReveal>

    <ScrollReveal delay={120}>
      <div class="reviews-shell mt-14">
        {/* FLÈCHES EXTÉRIEURES */}
        <button
          type="button"
          class="reviews-arrow reviews-arrow--left"
          aria-label="Avis précédents"
          data-reviews-prev
        >
          ←
        </button>

        <div class="reviews-stage">
          {/* Fade edges */}
          <div class="pointer-events-none absolute inset-y-0 left-0 w-16 bg-gradient-to-r from-base-100/95 to-transparent z-10"></div>
          <div class="pointer-events-none absolute inset-y-0 right-0 w-16 bg-gradient-to-l from-base-100/95 to-transparent z-10"></div>

          {/* TRACK */}
          <div
            class="reviews-carousel"
            data-reviews-track
            aria-label="Avis Google"
          >
            {[
              {
                name: "Mounir B.",
                text: "J’ai été refaire une duplication de clé. Très satisfait et par la même occasion j’ai fait un stage 1 de ma Peugeot 308… Je recommande les yeux fermés !",
              },
              {
                name: "Gor A.",
                text: "Problème de calculateur sur ma BMW 330e, réglé en une seule après-midi. Travail très professionnel, rapide et soigné… Je recommande vivement !",
              },
              {
                name: "Firas B.",
                text: "Intervention sur ma BMW E46. Correction électronique du pot catalytique. Service compétent avec un prix raisonnable et un délai compétitif.",
              },
              {
                name: "Jacques P.",
