---
const items = [
  {
    eyebrow: "01 — Diagnostic",
    title: "Identifier la cause, pas le symptôme.",
    desc:
      "Lecture défauts, tests ciblés, analyse capteurs/actionneurs et réseau (CAN). Un diagnostic clair avant d’agir.",
    bullets: ["Lecture défauts & mesures", "Tests ciblés", "Compte-rendu clair"],
    href: "/services/diagnostic",
  },
  {
    eyebrow: "02 — Programmation",
    title: "Programmation précise, sécurisée.",
    desc:
      "ECU, modules, adaptations : la bonne procédure, puis vérification. Zéro bricolage.",
    bullets: ["ECU / modules", "Codage & adaptations", "Validation post-op"],
    href: "/services/programmation",
  },
  {
    eyebrow: "03 — Réparation",
    title: "Réparation durable, contrôlée.",
    desc:
      "Réparation électronique avec contrôles et tests avant restitution. Objectif : fiabilité dans le temps.",
    bullets: ["Réparation électronique", "Contrôles & tests", "Fiabilité"],
    href: "/services/reparation",
  },
];
---

<section class="relative overflow-hidden">
  <!-- glow background (parallax) -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div class="glow glow-1 absolute -top-24 left-1/2 h-72 w-[52rem] -translate-x-1/2 rounded-full blur-3xl opacity-25 bg-gradient-to-r from-primary via-accent to-secondary"></div>
    <div class="glow glow-2 absolute -bottom-32 left-1/2 h-72 w-[52rem] -translate-x-1/2 rounded-full blur-3xl opacity-20 bg-gradient-to-r from-secondary via-primary to-accent"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-24">
    <div class="grid lg:grid-cols-12 gap-10 items-start">
      <!-- Sticky left -->
      <div class="lg:col-span-5 lg:sticky lg:top-24">
        <p class="text-white/60 font-medium">Faites défiler.</p>

        <h2 class="mt-3 text-4xl md:text-5xl font-bold leading-tight">
          Un process
          <span class="bg-gradient-to-r from-primary via-accent to-secondary bg-clip-text text-transparent">
            premium
          </span>
          .
        </h2>

        <!-- Dynamic panel -->
        <div class="mt-8 rounded-3xl border border-white/10 bg-base-200/70 backdrop-blur p-6 md:p-7">
          <div class="text-sm text-white/60 font-semibold" id="ss-eyebrow">{items[0].eyebrow}</div>
          <div class="mt-2 text-2xl md:text-3xl font-bold" id="ss-title">{items[0].title}</div>
          <p class="mt-3 text-white/70" id="ss-desc">{items[0].desc}</p>

          <div class="mt-5 flex gap-3">
            <a id="ss-link" href={items[0].href} class="btn btn-primary btn-sm">Détails</a>
            <a href="/contact" class="btn btn-outline btn-sm border-white/20">Devis</a>
          </div>

          <!-- Progress bar -->
          <div class="mt-6">
            <div class="flex items-center justify-between text-xs text-white/50">
              <span>Progression</span>
              <span id="ss-progress-text">1 / {items.length}</span>
            </div>
            <div class="mt-2 h-2 rounded-full bg-base-300/70 border border-white/10 overflow-hidden">
              <div id="ss-progress" class="h-full w-1/3 rounded-full bg-gradient-to-r from-primary via-accent to-secondary"></div>
            </div>
          </div>

          <!-- Dots -->
          <div class="mt-6 flex gap-2" aria-hidden="true">
            {items.map((_, i) => (
              <span class="dot h-2.5 w-2.5 rounded-full bg-white/20" data-dot={i}></span>
            ))}
          </div>
        </div>
      </div>

      <!-- Scroll content -->
      <div class="lg:col-span-7 space-y-6">
        {items.map((it, idx) => (
          <article class="showcase card bg-base-200 border border-white/10 rounded-3xl overflow-hidden" data-index={idx}>
            <div class="card-body p-7 md:p-9">
              <div class="flex items-center justify-between gap-4">
                <div class="text-sm text-white/60 font-semibold">{it.eyebrow}</div>
                <div class="badge badge-outline border-white/20 text-white/70">Autosoftronics</div>
              </div>

              <h3 class="mt-3 text-2xl md:text-3xl font-bold">{it.title}</h3>
              <p class="mt-3 text-white/70">{it.desc}</p>

              <ul class="mt-6 grid sm:grid-cols-3 gap-3">
                {it.bullets.map((b) => (
                  <li class="rounded-2xl bg-base-300/50 border border-white/10 px-4 py-3 text-sm text-white/75">
                    {b}
                  </li>
                ))}
              </ul>

              <div class="mt-6">
                <a class="link link-hover text-primary" href={it.href}>En savoir plus →</a>
              </div>
            </div>
          </article>
        ))}

        <!-- donne de la hauteur pour bien voir l'effet -->
        <div class="h-[25vh]"></div>
      </div>
    </div>
  </div>

  <script is:inline>
    window.addEventListener("DOMContentLoaded", () => {
      const cards = Array.from(document.querySelectorAll(".showcase"));
      const dots = Array.from(document.querySelectorAll(".dot"));

      const eyebrowEl = document.getElementById("ss-eyebrow");
      const titleEl = document.getElementById("ss-title");
      const descEl = document.getElementById("ss-desc");
      const linkEl = document.getElementById("ss-link");
      const progressEl = document.getElementById("ss-progress");
      const progressTextEl = document.getElementById("ss-progress-text");

      const data = [
        {
          eyebrow: "01 — Diagnostic",
          title: "Identifier la cause, pas le symptôme.",
          desc: "Lecture défauts, tests ciblés, analyse capteurs/actionneurs et réseau (CAN). Un diagnostic clair avant d’agir.",
          href: "/services/diagnostic",
        },
        {
          eyebrow: "02 — Programmation",
          title: "Programmation précise, sécurisée.",
          desc: "ECU, modules, adaptations : la bonne procédure, puis vérification. Zéro bricolage.",
          href: "/services/programmation",
        },
        {
          eyebrow: "03 — Réparation",
          title: "Réparation durable, contrôlée.",
          desc: "Réparation électronique avec contrôles et tests avant restitution. Objectif : fiabilité dans le temps.",
          href: "/services/reparation",
        },
      ];

      const prefersReduced =
        window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const setActive = (i) => {
        cards.forEach((c, idx) => c.classList.toggle("active", idx === i));
        dots.forEach((d, idx) => d.classList.toggle("active", idx === i));

        const it = data[i] || data[0];

        // micro "crossfade" sur le panneau sticky (Apple vibes)
        if (!prefersReduced) {
          [eyebrowEl, titleEl, descEl].forEach((el) => {
            if (!el) return;
            el.classList.remove("swap");
            // force reflow
            void el.offsetWidth;
            el.classList.add("swap");
          });
        }

        if (eyebrowEl) eyebrowEl.textContent = it.eyebrow;
        if (titleEl) titleEl.textContent = it.title;
        if (descEl) descEl.textContent = it.desc;
        if (linkEl) linkEl.setAttribute("href", it.href);

        const pct = ((i + 1) / data.length) * 100;
        if (progressEl) progressEl.style.width = pct + "%";
        if (progressTextEl) progressTextEl.textContent = `${i + 1} / ${data.length}`;
      };

      const io = new IntersectionObserver(
        (entries) => {
          const visible = entries
            .filter((e) => e.isIntersecting)
            .sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0];

          if (!visible) return;

          const i = Number(visible.target.getAttribute("data-index") || 0);
          setActive(i);
        },
        { threshold: [0.2, 0.35, 0.55, 0.75], rootMargin: "0px 0px -30% 0px" }
      );

      cards.forEach((c) => io.observe(c));
      setActive(0);

      // Parallax glow léger
      if (!prefersReduced) {
        const g1 = document.querySelector(".glow-1");
        const g2 = document.querySelector(".glow-2");
        const onScroll = () => {
          const y = window.scrollY || 0;
          if (g1) g1.style.transform = `translateX(-50%) translateY(${y * 0.04}px)`;
          if (g2) g2.style.transform = `translateX(-50%) translateY(${-y * 0.03}px)`;
        };
        onScroll();
        window.addEventListener("scroll", onScroll, { passive: true });
      }
    });
  </script>

  <style>
    /* cartes: effet très visible */
    .showcase {
      transform: translateY(18px) scale(.99);
      opacity: .55;
      filter: saturate(.85);
      transition:
        transform .65s ease,
        opacity .65s ease,
        border-color .65s ease,
        filter .65s ease;
    }
    .showcase.active {
      transform: translateY(0) scale(1);
      opacity: 1;
      border-color: rgba(255,255,255,.25);
      filter: saturate(1.08);
    }

    /* dots */
    .dot.active {
      background: rgba(255,255,255,.92);
      box-shadow: 0 0 0 6px rgba(150,50,225,.18);
    }

    /* crossfade du panneau sticky */
    .swap {
      animation: swapfade .35s ease both;
    }
    @keyframes swapfade {
      from { opacity: .55; transform: translateY(6px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>
</section>