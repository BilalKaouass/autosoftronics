---
import BaseLayout from "../layouts/BaseLayout.astro";
import Reveal from "../components/Reveal.astro";

const title = "À propos | Autosoftronics";
const description =
  "Découvrez Autosoftronics : nos valeurs, notre méthode de travail et notre atelier dédié à l’électromécanique automobile.";
---

<BaseLayout title={title} description={description}>
  <!-- HERO -->
<section class="relative overflow-hidden">
  <!-- Glow background -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute -top-24 left-1/2 h-72 w-[52rem] -translate-x-1/2 rounded-full blur-3xl opacity-30 bg-gradient-to-r from-primary via-accent to-secondary"></div>
    <div class="absolute -bottom-32 left-1/2 h-72 w-[52rem] -translate-x-1/2 rounded-full blur-3xl opacity-20 bg-gradient-to-r from-secondary via-primary to-accent"></div>
    <div class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(circle_at_1px_1px,white_1px,transparent_1px)] [background-size:24px_24px]"></div>
  </div>

  <div class="max-w-6xl mx-auto px-4 py-16 md:py-20 relative">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-10 items-start">
      <div class="lg:col-span-7">
        <Reveal>
          <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
            <span class="h-2 w-2 rounded-full bg-success"></span>
            À propos
          </div>
        </Reveal>

        <Reveal delay={80}>
<h1 class="mt-6 text-4xl md:text-5xl font-bold leading-[1.04] tracking-tight max-w-3xl">
            Autosoftronics,
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary via-accent to-secondary">
              l’exigence dans l’électromécanique auto
            </span>
            .
          </h1>
        </Reveal>

        <Reveal delay={160}>
          <p class="mt-5 text-white/70 text-base md:text-lg max-w-2xl leading-relaxed">
            Nous aidons les conducteurs et les professionnels à résoudre des problèmes complexes
            (diagnostic, programmation, réparation) avec une approche claire, précise et orientée résultat.
          </p>
        </Reveal>

        <Reveal delay={240}>
          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a class="btn btn-primary btn-lg shadow-lg shadow-primary/25" href="/contact">
              Nous contacter
            </a>
            <a class="btn btn-ghost border border-white/15" href="/services">
              Voir nos services
            </a>
          </div>
        </Reveal>

        <Reveal delay={320}>
          <div class="mt-6 flex flex-wrap gap-3">
            <div class="trust-pill">Approche claire</div>
            <div class="trust-pill">Diagnostic précis</div>
            <div class="trust-pill">Résultat durable</div>
          </div>
        </Reveal>
      </div>

      <div class="lg:col-span-5">
        <Reveal delay={180}>
          <div class="glass-card rounded-3xl p-6">
            <div class="flex items-center gap-3">
              <img
                src="/assets/brand/icon.png"
                alt="Autosoftronics"
                class="w-10 h-10"
                loading="lazy"
                width="40"
                height="40"
              />
              <div>
                <div class="font-semibold text-lg">Autosoftronics</div>
                <div class="text-white/60 text-sm">Diagnostic • Programmation • Réparation</div>
              </div>
            </div>

            <div class="mt-6 grid grid-cols-3 gap-3">
              <div class="mini-stat">
                <div class="text-sm text-white/55">Approche</div>
                <div class="font-semibold">Pro</div>
              </div>
              <div class="mini-stat">
                <div class="text-sm text-white/55">Objectif</div>
                <div class="font-semibold">Résultat</div>
              </div>
              <div class="mini-stat">
                <div class="text-sm text-white/55">Délai</div>
                <div class="font-semibold">Rapide</div>
              </div>
            </div>

            <div class="mt-6 rounded-2xl border border-white/10 bg-gradient-to-r from-primary/15 via-accent/10 to-secondary/15 p-4">
              <p class="text-white/70 text-sm leading-relaxed">
                Notre priorité : fournir un diagnostic fiable, expliquer clairement les options,
                et proposer une solution durable.
              </p>
            </div>
          </div>
        </Reveal>
      </div>
    </div>
  </div>
</section>

  <!-- VALEURS -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <Reveal>
      <h2 class="text-3xl md:text-4xl font-bold">Nos valeurs</h2>
    </Reveal>

    <Reveal delay={100}>
      <p class="mt-4 text-white/70 max-w-2xl leading-relaxed">
        Trois piliers qui guident chacune de nos interventions, du premier échange jusqu’à la livraison.
      </p>
    </Reveal>

    <div class="mt-10 grid md:grid-cols-3 gap-6">
      <Reveal>
        <div class="glass-card rounded-3xl p-6 h-full">
          <div class="badge badge-outline border-white/20 text-white/70">Transparence</div>
          <h3 class="mt-4 text-xl font-semibold">Explications claires</h3>
          <p class="mt-3 text-white/70 leading-relaxed">
            On vous explique ce que nous observons, pourquoi, et quelles sont les options — sans jargon inutile.
          </p>
        </div>
      </Reveal>

      <Reveal delay={120}>
        <div class="glass-card rounded-3xl p-6 h-full">
          <div class="badge badge-outline border-white/20 text-white/70">Précision</div>
          <h3 class="mt-4 text-xl font-semibold">Diagnostic fiable</h3>
          <p class="mt-3 text-white/70 leading-relaxed">
            Mesures, contrôles et logique de panne : nous cherchons la cause, pas seulement le symptôme.
          </p>
        </div>
      </Reveal>

      <Reveal delay={240}>
        <div class="glass-card rounded-3xl p-6 h-full">
          <div class="badge badge-outline border-white/20 text-white/70">Qualité</div>
          <h3 class="mt-4 text-xl font-semibold">Solutions durables</h3>
          <p class="mt-3 text-white/70 leading-relaxed">
            Réparation sérieuse et tests après intervention pour éviter les retours et les mauvaises surprises.
          </p>
        </div>
      </Reveal>
    </div>
  </section>

  <!-- METHODE -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="grid lg:grid-cols-12 gap-14 items-start">
      <div class="lg:col-span-5">
        <Reveal>
          <h2 class="text-3xl md:text-4xl font-bold">Notre méthode</h2>
        </Reveal>

        <Reveal delay={100}>
          <p class="mt-4 text-white/70 leading-relaxed">
            Une approche structurée, inspirée des ateliers “haut niveau” : collecte d’infos, diagnostic,
            validation, puis intervention et tests.
          </p>
        </Reveal>

        <Reveal delay={200}>
          <div class="mt-6 glass-card rounded-3xl p-6">
            <div class="text-sm text-white/60">Ce que vous gagnez</div>
            <ul class="mt-4 space-y-3 text-white/70">
              <li class="flex gap-3">
                <span class="service-bullet mt-2 shrink-0"></span>
                <span>Un plan clair avant d’agir</span>
              </li>
              <li class="flex gap-3">
                <span class="service-bullet mt-2 shrink-0"></span>
                <span>Moins d’essais inutiles</span>
              </li>
              <li class="flex gap-3">
                <span class="service-bullet mt-2 shrink-0"></span>
                <span>Une réparation testée et validée</span>
              </li>
            </ul>
          </div>
        </Reveal>
      </div>

      <div class="lg:col-span-7">
        <div class="space-y-10">
          <Reveal>
            <div class="about-step">
              <div class="about-step__rail">
                <span class="about-step__dot"></span>
                <span class="about-step__line"></span>
              </div>
              <div class="about-step__content">
                <div class="about-step__top">
                  <span class="about-step__num">01</span>
                  <h3 class="about-step__title">Analyse & symptômes</h3>
                </div>
                <p class="about-step__text">
                  On collecte les infos, l’historique et les symptômes pour orienter le diagnostic.
                </p>
              </div>
            </div>
          </Reveal>

          <Reveal delay={120}>
            <div class="about-step">
              <div class="about-step__rail">
                <span class="about-step__dot"></span>
                <span class="about-step__line"></span>
              </div>
              <div class="about-step__content">
                <div class="about-step__top">
                  <span class="about-step__num">02</span>
                  <h3 class="about-step__title">Diagnostic & mesures</h3>
                </div>
                <p class="about-step__text">
                  Lecture défauts, tests, contrôles capteurs/actionneurs, analyse réseaux (CAN), etc.
                </p>
              </div>
            </div>
          </Reveal>

          <Reveal delay={240}>
            <div class="about-step">
              <div class="about-step__rail">
                <span class="about-step__dot"></span>
              </div>
              <div class="about-step__content">
                <div class="about-step__top">
                  <span class="about-step__num">03</span>
                  <h3 class="about-step__title">Intervention & validation</h3>
                </div>
                <p class="about-step__text">
                  Réparation / programmation selon besoin, puis tests de validation avant restitution.
                </p>
              </div>
            </div>
          </Reveal>
        </div>
      </div>
    </div>
  </section>

  <!-- ATELIER -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <div class="glass-card rounded-[2rem] p-8 md:p-10 overflow-hidden relative">
      <div class="pointer-events-none absolute inset-0">
        <div class="absolute inset-0 bg-gradient-to-br from-primary/10 via-transparent to-secondary/10"></div>
      </div>

      <div class="relative grid lg:grid-cols-12 gap-8 items-center">
        <div class="lg:col-span-7">
          <Reveal>
            <h2 class="text-3xl md:text-4xl font-bold">L’atelier</h2>
          </Reveal>

          <Reveal delay={120}>
            <p class="mt-4 text-white/70 leading-relaxed">
              Un environnement pensé pour travailler proprement : outils adaptés, procédures,
              et une attention particulière aux détails qui font la différence.
            </p>
          </Reveal>

          <Reveal delay={240}>
            <div class="mt-6 grid sm:grid-cols-2 gap-4">
              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <div class="font-semibold">Outillage & contrôle</div>
                <div class="text-white/60 text-sm mt-1">
                  Tests ciblés, vérifications, mesures, validation post-intervention.
                </div>
              </div>

              <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
                <div class="font-semibold">Propreté & méthode</div>
                <div class="text-white/60 text-sm mt-1">
                  Interventions structurées, traçabilité et retour clair au client.
                </div>
              </div>
            </div>
          </Reveal>
        </div>

        <div class="lg:col-span-5">
          <Reveal delay={180}>
            <div class="rounded-3xl border border-white/10 p-6 bg-gradient-to-br from-primary/15 via-accent/10 to-secondary/15">
              <div class="text-sm text-white/60">Besoin d’un avis ?</div>
              <div class="mt-2 text-xl font-semibold">Parlons de votre problème</div>
              <p class="mt-3 text-white/70 text-sm leading-relaxed">
                Décrivez les symptômes, les codes défauts éventuels et le modèle du véhicule.
                On revient vers vous rapidement.
              </p>
              <a class="btn btn-primary w-full mt-5 shadow-lg shadow-primary/25" href="/contact">
                Contacter Autosoftronics
              </a>
            </div>
          </Reveal>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="max-w-6xl mx-auto px-4 pb-20">
    <div class="rounded-3xl border border-white/10 bg-base-200/60 backdrop-blur-xl p-8 md:p-10">
      <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
        <div>
          <h2 class="text-2xl md:text-3xl font-bold">
            Prêt à diagnostiquer, programmer ou réparer ?
          </h2>
          <p class="mt-2 text-white/70">
            Contactez-nous et recevez une réponse rapide.
          </p>
        </div>
        <div class="flex gap-3 flex-wrap">
          <a class="btn btn-primary shadow-lg shadow-primary/25" href="/contact">Demander un devis</a>
          <a class="btn btn-ghost border border-white/15" href="/services">Nos services</a>
        </div>
      </div>
    </div>
  </section>

  <style>
    .glass-card{
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(18,18,24,.35);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      box-shadow:
        0 0 0 1px rgba(255,255,255,.04) inset,
        0 24px 50px rgba(0,0,0,.28);
    }

    .mini-stat{
      border: 1px solid rgba(255,255,255,.10);
      background: rgba(255,255,255,.04);
      border-radius: 16px;
      padding: 14px;
      text-align: center;
    }

    .trust-pill{
      display:inline-flex;
      align-items:center;
      gap:10px;
      padding:10px 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.14);
      background:rgba(255,255,255,.05);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      box-shadow: 0 0 0 1px rgba(255,255,255,.04) inset;
    }

    .trust-pill::before{
      content:"";
      width:7px;
      height:7px;
      border-radius:999px;
      background:rgba(34,197,94,.95);
      box-shadow:0 0 0 4px rgba(34,197,94,.12);
    }

    .service-bullet{
      width:6px;
      height:6px;
      border-radius:999px;
      background: rgba(139,92,246,.95);
      box-shadow: 0 0 0 4px rgba(139,92,246,.12);
      display:inline-block;
    }

    .about-step{
      display:flex;
      gap:22px;
      align-items:flex-start;
      padding:8px 0;
    }

    .about-step__rail{
      width:26px;
      display:flex;
      flex-direction:column;
      align-items:center;
      flex:0 0 26px;
      padding-top:8px;
    }

    .about-step__dot{
      width:11px;
      height:11px;
      border-radius:9999px;
      background: rgba(139,92,246,.95);
      box-shadow:
        0 0 0 8px rgba(139,92,246,.10),
        0 0 18px rgba(139,92,246,.22);
      flex:0 0 auto;
    }

    .about-step__line{
      width:1px;
      flex:1 1 auto;
      margin-top:14px;
      min-height:82px;
      background: linear-gradient(
        to bottom,
        rgba(139,92,246,.42),
        rgba(255,255,255,.08),
        rgba(255,255,255,0)
      );
    }

    .about-step__content{
      flex:1 1 auto;
      min-width:0;
    }

    .about-step__top{
      display:flex;
      align-items:center;
      gap:18px;
    }

    .about-step__num{
      font-size:30px;
      line-height:1;
      font-weight:700;
      color: rgba(139,92,246,.95);
      min-width:54px;
    }

    .about-step__title{
      margin:0;
      font-size:22px;
      line-height:1.2;
      font-weight:700;
      color:white;
    }

    .about-step__text{
      margin-top:14px;
      color:rgba(255,255,255,.66);
      line-height:1.85;
      font-size:15px;
      max-width:32rem;
    }

    @media (max-width: 768px){
      .about-step{
        gap:18px;
      }

      .about-step__rail{
        width:24px;
        flex:0 0 24px;
      }

      .about-step__num{
        font-size:24px;
        min-width:40px;
      }

      .about-step__title{
        font-size:19px;
      }

      .about-step__text{
        font-size:14px;
        line-height:1.7;
      }

      .about-step__line{
        min-height:70px;
      }
    }
  </style>
</BaseLayout>