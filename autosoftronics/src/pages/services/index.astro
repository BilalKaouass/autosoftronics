---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ScrollReveal from "../../components/ScrollReveal.astro";
import { services } from "../../data/services";
---

<BaseLayout
  title="Services | Autosoftronics"
  description="Diagnostic, programmation ECU & modules, réparation électronique — une méthode rigoureuse et premium."
>
  <section class="relative overflow-hidden pt-24 pb-24">
    <div class="pointer-events-none absolute inset-0 -z-10">
      <div class="absolute -top-24 left-1/2 h-72 w-[58rem] -translate-x-1/2 rounded-full blur-3xl opacity-15 bg-gradient-to-r from-secondary via-primary to-accent"></div>
      <div class="absolute inset-0 opacity-[0.03] bg-[radial-gradient(circle_at_1px_1px,white_1px,transparent_1px)] [background-size:22px_22px]"></div>
    </div>

    <div class="max-w-6xl mx-auto px-4">
      <ScrollReveal>
        <div class="text-center">
          <div class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2 text-sm text-white/70 backdrop-blur">
            <span class="h-2 w-2 rounded-full bg-success"></span>
            Services
          </div>

          <h1 class="mt-6 text-4xl md:text-6xl font-bold tracking-tight">
            Nos services
          </h1>

          <p class="mt-4 text-white/70 max-w-2xl mx-auto leading-relaxed">
            Diagnostic précis, programmation sécurisée, réparation fiable — avec validation avant restitution.
          </p>
        </div>
      </ScrollReveal>

      <ScrollReveal delay={140}>
        <div class="mt-14 grid gap-6 md:grid-cols-3">
          {services.map((s) => (
            <a
              href={`/services/${s.slug}`}
              class="service-card group relative rounded-3xl border border-white/10 bg-base-200/35 backdrop-blur-xl p-8
                     hover:border-white/20 hover:bg-base-200/55 transition overflow-hidden"
            >
              <div class="absolute inset-0 rounded-3xl opacity-0 group-hover:opacity-100 transition bg-gradient-to-r from-primary/10 via-accent/8 to-secondary/10"></div>
              <div class="sweep absolute inset-0 rounded-3xl pointer-events-none"></div>

              <div class="relative">
                <div class="text-sm text-white/60 font-medium">
                  {s.hero?.eyebrow ?? "Service"}
                </div>

                <div class="mt-2 text-2xl font-bold">
                  {s.hero?.title ?? s.name}
                </div>

                <p class="mt-3 text-white/70 leading-relaxed">
                  {s.hero?.subtitle ?? s.short}
                </p>

                {s.highlights?.length ? (
                  <div class="mt-6 flex flex-wrap gap-2">
                    {s.highlights.slice(0, 3).map((h) => (
                      <span class="badge badge-outline border-white/20 text-white/70">
                        {h.label}: {h.value}
                      </span>
                    ))}
                  </div>
                ) : null}

                <div class="mt-8 inline-flex items-center gap-2 font-semibold text-primary">
                  Voir le détail <span class="transition group-hover:translate-x-1">→</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </ScrollReveal>

      <div class="mt-14 text-center">
        <a href="/contact" class="btn btn-primary btn-lg shadow-lg shadow-primary/25">
          Demander un devis
        </a>
        <div class="mt-4 text-sm text-white/60">
          Réponse rapide • Devis clair • Intervention maîtrisée
        </div>
      </div>
    </div>

    <style>
      .service-card .sweep::before{
        content:"";
        position:absolute; inset:-40%;
        background: linear-gradient(115deg, transparent 45%, rgba(255,255,255,.08) 50%, transparent 55%);
        transform: translateX(-30%) rotate(8deg);
        opacity: 0;
        transition: transform .6s ease, opacity .6s ease;
      }
      .service-card:hover .sweep::before{
        opacity: 1;
        transform: translateX(30%) rotate(8deg);
      }
      @media (prefers-reduced-motion: reduce) {
        .service-card .sweep::before { display:none; }
      }
    </style>
  </section>
</BaseLayout>